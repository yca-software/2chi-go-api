CONFIG_PATH=./config.yaml
# Shared local Postgres (local-env/docker-compose.yml)
2CHI_POSTGRES__DSN=postgres://postgres:postgres@localhost:5432/2chi?sslmode=disable

2CHI_REDIS__SESSION_DSN=redis://localhost:6379/0
2CHI_REDIS__RATE_LIMIT_DSN=redis://localhost:6379/1

2CHI_AUTH__ACCESS_TOKEN_SECRET=local-dev-access-token-secret-32chars-min
2CHI_AUTH__TOKEN_HASH_PEPPER=local-dev-token-hash-pepper-32chars-min

2CHI_GOOGLE__OAUTH__CLIENT_ID=replace-me
2CHI_GOOGLE__OAUTH__CLIENT_SECRET=replace-me
2CHI_GOOGLE__MAPS__API_KEY=replace-me

2CHI_PADDLE__API_KEY=replace-me
2CHI_PADDLE__WEBHOOK_SECRET=replace-me
# Must match react-spa VITE_PADDLE_PRICE_*
2CHI_PADDLE__PRICES__BASIC_MONTHLY=replace-me
2CHI_PADDLE__PRICES__BASIC_ANNUAL=replace-me
2CHI_PADDLE__PRICES__PRO_MONTHLY=replace-me
2CHI_PADDLE__PRICES__PRO_ANNUAL=replace-me
